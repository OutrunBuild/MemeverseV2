{
  "delegated_review_rules": [
    {
      "id": "harness-control",
      "paths": [
        "^\\.harness/.*$",
        "^script/harness/.*$",
        "^\\.github/workflows/.*$"
      ],
      "requires_human_confirmation": false,
      "reviewers": []
    },
    {
      "exclude_paths": [
        "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
      ],
      "id": "non-spec-doc",
      "paths": [
        "^docs/.*$"
      ],
      "requires_human_confirmation": false,
      "reviewers": []
    }
  ],
  "full_review_matrix": {
    "no-op": [],
    "non-semantic": [],
    "prod-semantic": [
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer"
    ],
    "test-semantic": [
      "logic-reviewer"
    ]
  },
  "hard_blocks": [],
  "orchestration_review_roles": {
    "no-op": [],
    "non-semantic": [],
    "prod-semantic-risk-analysis-passed": [
      "logic-reviewer"
    ],
    "test-semantic": [
      "logic-reviewer"
    ]
  },
  "orchestration_rules": {
    "scope_escalation": {
      "prod_solidity_max_files_before_full_review": 1,
      "prod_solidity_max_semantic_lines_before_full_review": 20
    },
    "spec_paths": [
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
    ],
    "surface_sensitivity": {
      "harness_control": "normal",
      "solidity_prod": "sensitive",
      "solidity_test": "normal"
    }
  },
  "repo": "MemeverseV2",
  "risk_rules": {
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions",
    "slither_filter_paths": "lib|test|script|node_modules"
  },
  "surfaces": {
    "harness_control": [
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$",
      "^AGENTS\\.md$",
      "^(src|test|script)/AGENTS\\.md$",
      "^CLAUDE\\.md$",
      "^README\\.md$",
      "^\\.claude/agents/.*$",
      "^\\.claude/rules/.*$",
      "^\\.claude/settings\\.json$",
      "^\\.codex/agents/.*$",
      "^\\.githooks/.*$",
      "^\\.github/pull_request_template\\.md$",
      "^\\.github/workflows/.*$",
      "^\\.github/workflows/pr-template-check\\.yml$",
      "^\\.gitmodules$",
      "^\\.gitignore$",
      "^\\.harness/policy\\.json$",
      "^\\.harness/runtime/main-session-contract\\.md$",
      "^\\.harness/schemas/.*$",
      "^docs/.*$",
      "^foundry\\.toml$",
      "^lib/LayerZero-v2$",
      "^lib/devtools$",
      "^lib/flexible-voting$",
      "^lib/forge-std$",
      "^lib/openzeppelin-contracts-upgradeable$",
      "^lib/openzeppelin-foundry-upgrades$",
      "^lib/solidity-bytes-utils$",
      "^lib/solmate$",
      "^lib/v4-core$",
      "^lib/v4-hooks-public$",
      "^lib/v4-periphery$",
      "^npm-shrinkwrap\\.json$",
      "^package-lock\\.json$",
      "^package\\.json$",
      "^remappings\\.txt$",
      "^script/harness/.*$",
      "^solhint.*\\.config\\.js$"
    ],
    "solidity_prod": [
      "^src/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "solidity_test": [
      "^test/.*\\.sol$"
    ]
  },
