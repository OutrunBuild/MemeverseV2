{
  "delegated_review_rules": [
    {
      "id": "spec-path",
      "paths": [
        "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
      ],
      "requires_human_confirmation": true,
      "reviewers": [
        "spec-reviewer"
      ]
    },
    {
      "id": "spec-readiness-doc-update",
      "requires_human_confirmation": true,
      "reviewers": [
        "spec-reviewer"
      ],
      "trigger": "spec-readiness-doc-update"
    },
    {
      "id": "harness-control",
      "paths": [
        "^\\.harness/.*$",
        "^script/harness/.*$",
        "^\\.github/workflows/.*$"
      ],
      "requires_human_confirmation": false,
      "reviewers": []
    },
    {
      "exclude_paths": [
        "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
      ],
      "id": "non-spec-doc",
      "paths": [
        "^docs/.*$"
      ],
      "requires_human_confirmation": false,
      "reviewers": []
    }
  ],
  "full_review_matrix": {
    "no-op": [],
    "non-semantic": [],
    "prod-semantic": [
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer"
    ],
    "test-semantic": [
      "logic-reviewer"
    ]
  },
  "hard_blocks": [],
  "orchestration_profiles": {
    "blocked": {
      "reviewers": [],
      "verification_profile": "none",
      "verifier": "none",
      "writer": "none"
    },
    "delegated": {
      "reviewers": "delegated-selected",
      "verification_profile": "fast",
      "verifier": "main-session",
      "writer": "policy-selected"
    },
    "direct": {
      "reviewers": [],
      "verification_profile": "fast",
      "verifier": "main-session",
      "writer": "main-session"
    },
    "direct-review": {
      "reviewers": "orchestration-selected",
      "verification_profile": "fast",
      "verifier": "main-session",
      "writer": "main-session"
    },
    "full-review": {
      "reviewers": "full-review-matrix",
      "verification_profile": "fast",
      "verifier": "main-session",
      "writer": "policy-selected"
    },
    "full-subagent": {
      "reviewers": "full-review-matrix",
      "verification_profile": "selected",
      "verifier": "required-verifier-agent",
      "writer": "policy-selected"
    },
    "no-op": {
      "reviewers": [],
      "verification_profile": "none",
      "verifier": "none",
      "writer": "none"
    }
  },
  "orchestration_review_roles": {
    "no-op": [],
    "non-semantic": [],
    "prod-semantic-risk-analysis-passed": [
      "logic-reviewer"
    ],
    "test-semantic": [
      "logic-reviewer"
    ]
  },
  "orchestration_rules": {
    "delegated_surface": "harness_control",
    "full_ci_command_gates": {
      "coverage_when_required": {
        "change_class": "prod-semantic",
        "surface_sensitivity": "sensitive"
      },
      "slither_when_required": {
        "change_class": "prod-semantic",
        "paths": [
          "^src/.*\\.sol$"
        ],
        "surface_sensitivity": "sensitive"
      }
    },
    "main_session_risk_analysis_required_for": [
      "semantic production Solidity changes not structurally escalated"
    ],
    "scope_escalation": {
      "prod_solidity_max_files_before_full_review": 1,
      "prod_solidity_max_semantic_lines_before_full_review": 20
    },
    "spec_paths": [
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
    ],
    "surface_sensitivity": {
      "harness_control": "normal",
      "solidity_prod": "sensitive",
      "solidity_test": "normal"
    }
  },
  "orchestration_writer_rules": [
    {
      "id": "spec-doc",
      "paths": [
        "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
      ],
      "writer": "process-implementer"
    },
    {
      "id": "spec-readiness-doc-update",
      "trigger": "spec-readiness-doc-update",
      "writer": "process-implementer"
    },
    {
      "id": "harness-control",
      "paths": [
        "^\\.harness/.*$",
        "^script/harness/.*$",
        "^\\.github/workflows/.*$",
        "^AGENTS\\.md$",
        "^CLAUDE\\.md$"
      ],
      "writer": "process-implementer"
    },
    {
      "id": "repo-metadata",
      "paths": [
        "^package\\.json$",
        "^package-lock\\.json$",
        "^npm-shrinkwrap\\.json$"
      ],
      "writer": "process-implementer"
    },
    {
      "id": "docs",
      "paths": [
        "^docs/.*$",
        "^README\\.md$"
      ],
      "writer": "process-implementer"
    }
  ],
  "remediation_policy": {
    "conflict_priority": [
      "security-reviewer",
      "gas-reviewer",
      "logic-reviewer"
    ],
    "escalation": "user",
    "max_cycles": 5
  },
  "repo": "MemeverseV2",
  "risk_rules": {
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions",
    "slither_filter_paths": "lib|test|script|node_modules"
  },
  "security_test_writer_trigger": {
    "change_class": "prod-semantic",
    "reviewer_finding_severity_to_activate": "critical",
    "selected_review_roles_include": [
      "security-reviewer"
    ]
  },
  "spec_readiness_gate": {
    "cross_cutting_docs": [
      "docs/ARCHITECTURE.md",
      "docs/spec/access-control.md",
      "docs/spec/upgradeability.md",
      "docs/operations.md",
      "docs/spec/protocol.md",
      "docs/implementation-map.md",
      "docs/GLOSSARY.md"
