{
  "version": 1,
  "repo": "MemeverseV2",
  "surfaces": {
    "solidity_prod": [
      "^src/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "solidity_test": [
      "^test/.*\\.sol$"
    ],
    "harness_control": [
      "^AGENTS\\.md$",
      "^README\\.md$",
      "^CLAUDE\\.md$",
      "^package\\.json$",
      "^\\.gitignore$",
      "^\\.github/workflows/.*$",
      "^\\.github/pull_request_template\\.md$",
      "^\\.github/workflows/pr-template-check\\.yml$",
      "^\\.githooks/.*$",
      "^script/harness/.*$",
      "^\\.harness/policy\\.json$",
      "^\\.harness/runtime/main-session-contract\\.md$",
      "^\\.harness/schemas/.*$",
      "^\\.claude/settings\\.json$",
      "^\\.claude/agents/.*$",
      "^\\.codex/agents/.*$",
      "^docs/ARCHITECTURE\\.md$",
      "^docs/TRACEABILITY\\.md$",
      "^docs/VERIFICATION\\.md$",
      "^docs/GLOSSARY\\.md$",
      "^docs/SECURITY_AND_APPROVALS\\.md$",
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$",
      "^solhint.*\\.config\\.js$",
      "^foundry\\.toml$",
      "^remappings\\.txt$",
      "^package-lock\\.json$",
      "^npm-shrinkwrap\\.json$"
    ]
  },
  "write_roles": {
    "solidity_prod": "solidity-implementer",
    "solidity_test": "solidity-implementer",
    "harness_control": "process-implementer"
  },
  "risk_rules": {
    "high_risk_paths": [
      "^src/common/.*\\.sol$",
      "^src/governance/.*\\.sol$",
      "^src/interoperation/.*\\.sol$",
      "^src/swap/.*\\.sol$",
      "^src/token/.*\\.sol$",
      "^src/verse/.*\\.sol$",
      "^src/yield/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "high_risk_tokens": [
      "\\bdelegatecall\\b",
      "\\bselfdestruct\\b",
      "\\bassembly\\b",
      "\\bcallcode\\b"
    ],
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions"
  },
  "review_matrix": {
    "non-semantic": [],
    "test-semantic": [
      "logic-reviewer"
    ],
    "prod-semantic": [
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer"
    ],
    "high-risk": [
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer"
    ]
  },
  "review_triggers": [
    {
      "id": "spec-doc-review",
      "reviewer_role": "spec-reviewer",
      "paths": [
        "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
      ],
      "surfaces": [
        "harness_control"
      ]
    }
  ],
  "security_test_writer_trigger": {
    "risk_tiers": ["high-risk"],
    "reviewer_finding_severity_to_activate": "critical"
  },
  "remediation_policy": {
    "max_cycles": 5,
    "conflict_priority": ["security-reviewer", "gas-reviewer", "logic-reviewer"],
    "escalation": "user"
  },
  "verification_profiles": {
    "fast": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "targeted_tests",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "full": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "ci": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    }
  },
  "hard_blocks": [
    {
      "id": "mixed-harness-control-and-solidity",
      "message": "harness_control changes must not be mixed with Solidity surfaces",
      "mixed_surface_sets": [
        [
          "harness_control",
          "solidity_prod"
        ],
        [
          "harness_control",
          "solidity_test"
        ]
      ]
    }
  ],
  "testing_gaps": {
    "memeverse": [
      {
        "id": "common-foundations",
        "paths": [
          "src/common/access/ReentrancyGuard.sol",
          "src/common/interfaces/IBurnable.sol",
          "src/common/omnichain/oapp/OutrunOAppPreCrimeSimulatorInit.sol",
          "src/common/token/TokenHelper.sol"
        ],
        "status": "partial-targeted-rule",
        "enforcement": "residual-risk"
      },
      {
        "id": "unlock-protection-dedicated-tests",
        "paths": [
          "src/verse/MemeverseLauncher.sol",
          "src/swap/MemeverseSwapRouter.sol",
          "src/swap/MemeverseUniswapHook.sol"
        ],
        "status": "missing-dedicated-rule-tests",
        "enforcement": "risk-upgrade"
      }
    ]
  },
