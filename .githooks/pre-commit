#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! git diff --cached --name-only --diff-filter=ACMR | grep -Eq '^src/.*\.sol$'; then
    exit 0
fi

echo "Regenerating contract docs for staged Solidity changes..."
npm run docs:gen
git add docs/src
