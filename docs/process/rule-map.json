    },
    {
      "id": "unlock-protection-dedicated-tests",
      "paths": [
        "src/verse/MemeverseLauncher.sol",
        "src/swap/MemeverseSwapRouter.sol",
        "src/swap/MemeverseUniswapHook.sol"
