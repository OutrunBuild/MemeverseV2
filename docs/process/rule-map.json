{
  "version": 2,
  "defaults": {
    "change_requirement_mode": "none",
    "evidence_requirement_mode": "any"
  },
  "rules": [
    {
      "id": "swap-router-core",
      "description": "Router core or router interface changes must carry router execution or interface coverage.",
      "owners": ["swap"],
      "triggers": {
        "any_of": [
          "src/swap/MemeverseSwapRouter.sol",
          "src/swap/interfaces/IMemeverseSwapRouter.sol"
        ]
      },
      "change_requirement": {
        "mode": "any",
        "tests": [
          "test/swap/MemeverseSwapRouter.t.sol",
          "test/swap/MemeverseSwapRouterPermit2.t.sol",
          "test/swap/MemeverseSwapRouterInterface.t.sol"
        ]
      },
      "evidence_requirement": {
        "mode": "any",
        "tests": [
          "test/swap/MemeverseSwapRouter.t.sol",
          "test/swap/MemeverseSwapRouterPermit2.t.sol",
          "test/swap/MemeverseSwapRouterInterface.t.sol"
        ]
      }
    },
    {
      "id": "swap-hook-liquidity",
      "description": "Hook, liquidity quote, LP token, or hook interface changes must carry liquidity-path coverage.",
      "owners": ["swap"],
      "triggers": {
        "any_of": [
          "src/swap/MemeverseUniswapHook.sol",
          "src/swap/libraries/LiquidityQuote.sol",
          "src/swap/tokens/UniswapLP.sol",
          "src/swap/interfaces/IMemeverseUniswapHook.sol"
        ]
      },
      "change_requirement": {
        "mode": "any",
        "tests": [
          "test/swap/MemeverseUniswapHookLiquidity.t.sol"
        ]
      },
      "evidence_requirement": {
        "mode": "any",
        "tests": [
          "test/swap/MemeverseUniswapHookLiquidity.t.sol",
          "test/swap/MemeverseSwapRouter.t.sol"
        ]
      }
    },
    {
      "id": "swap-liquidity-math",
      "description": "Liquidity math changes must be reflected in at least one swap or hook liquidity test.",
      "owners": ["swap"],
      "triggers": {
        "any_of": [
          "src/swap/libraries/LiquidityAmounts.sol"
        ]
      },
      "change_requirement": {
        "mode": "any",
        "tests": [
          "test/swap/MemeverseSwapRouter.t.sol",
          "test/swap/MemeverseSwapRouterPermit2.t.sol",
          "test/swap/MemeverseUniswapHookLiquidity.t.sol"
        ]
      },
      "evidence_requirement": {
        "mode": "any",
        "tests": [
          "test/swap/MemeverseSwapRouter.t.sol",
          "test/swap/MemeverseSwapRouterPermit2.t.sol",
          "test/swap/MemeverseUniswapHookLiquidity.t.sol",
          "test/swap/MemeverseDynamicFeeSimulation.t.sol"
        ]
      }
    },
    {
      "id": "launcher-core",
      "description": "Launcher changes must carry launcher config or fee-preview coverage.",
      "owners": ["verse"],
      "triggers": {
        "any_of": [
          "src/verse/MemeverseLauncher.sol",
          "src/verse/interfaces/IMemeverseLauncher.sol"
        ]
      },
      "change_requirement": {
        "mode": "any",
        "tests": [
          "test/verse/MemeverseLauncherLifecycle.t.sol",
          "test/verse/MemeverseLauncherConfig.t.sol",
          "test/verse/MemeverseLauncherRegistration.t.sol",
          "test/verse/MemeverseLauncherViews.t.sol"
        ]
      },
      "evidence_requirement": {
        "mode": "any",
        "tests": [
          "test/verse/MemeverseLauncherLifecycle.t.sol",
          "test/verse/MemeverseLauncherConfig.t.sol",
          "test/verse/MemeverseLauncherRegistration.t.sol",
          "test/verse/MemeverseLauncherViews.t.sol"
        ]
      }
    },
    {
      "id": "launcher-price-math",
      "description": "Initial price calculator changes must carry dedicated price math coverage.",
      "owners": ["verse"],
      "triggers": {
        "any_of": [
          "src/verse/libraries/InitialPriceCalculator.sol"
        ]
      },
      "change_requirement": {
        "mode": "any",
        "tests": [
          "test/verse/libraries/InitialPriceCalculator.t.sol"
        ]
      },
      "evidence_requirement": {
        "mode": "any",
        "tests": [
          "test/verse/libraries/InitialPriceCalculator.t.sol"
        ]
      }
    }
  ],
  "testing_gaps": [
    {
      "id": "verse-registration",
      "paths": [
        "src/verse/registration/",
        "src/verse/MemeverseOFTDispatcher.sol",
        "src/verse/deployment/"
      ],
      "status": "missing-targeted-rule"
    },
    {
      "id": "governance",
      "paths": [
        "src/governance/"
      ],
      "status": "missing-targeted-rule"
    },
    {
      "id": "interoperation",
      "paths": [
        "src/interoperation/"
      ],
      "status": "missing-targeted-rule"
    },
    {
      "id": "token-and-yield",
      "paths": [
        "src/token/",
        "src/yield/"
      ],
      "status": "missing-targeted-rule"
    },
    {
      "id": "common",
      "paths": [
        "src/common/"
      ],
      "status": "missing-targeted-rule"
    }
  ]
}
