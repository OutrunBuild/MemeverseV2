  "testing_gaps": [
    {
      "id": "common-foundations",
      "paths": [
        "src/common/access/ReentrancyGuard.sol",
        "src/common/interfaces/IBurnable.sol",
        "src/common/omnichain/oapp/OutrunOAppPreCrimeSimulatorInit.sol",
        "src/common/token/TokenHelper.sol"
