        "mode": "any",
        "tests": [
          "test/verse/registration/MemeverseRegistrarAtLocal.t.sol",
          "test/verse/registration/MemeverseRegistrarOmnichain.t.sol",
          "test/verse/registration/MemeverseRegistrationCenter.t.sol",
          "test/verse/MemeverseLauncherRegistration.t.sol"
        ]
      }
