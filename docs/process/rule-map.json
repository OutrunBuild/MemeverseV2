        "tests": [
          "test/verse/YieldDispatcher.t.sol",
          "test/verse/deployment/MemeverseProxyDeployer.t.sol"
        ]
      },
      "evidence_requirement": {
        "mode": "any",
        "tests": [
          "test/verse/YieldDispatcher.t.sol",
          "test/verse/deployment/MemeverseProxyDeployer.t.sol",
          "test/verse/MemeverseLauncherLifecycle.t.sol"
        ]
      }
    },
