{
  "review_note": {
    "required_headings": [
      "## Scope",
      "## Impact",
      "## Findings",
      "## Simplification",
      "## Gas",
      "## Docs",
      "## Tests",
      "## Verification",
      "## Decision"
    ],
    "required_fields": [
      "Change summary",
      "Files reviewed",
      "Semantic dimensions reviewed",
      "Source-of-truth docs checked",
      "External facts checked",
      "Local control-flow facts checked",
      "Evidence chain complete",
      "Semantic alignment summary",
      "Behavior change",
      "ABI change",
      "Storage layout change",
      "Config change",
      "Security review summary",
      "Security residual risks",
      "Open safety mismatches assessed",
      "Gas-sensitive paths reviewed",
      "Gas changes applied",
      "Gas snapshot/result",
      "Gas residual risks",
      "Docs updated",
      "Tests updated",
      "Existing tests exercised",
      "Commands run",
      "Results",
      "Ready to commit",
      "Residual risks"
    ],
    "boolean_fields": [
      "Evidence chain complete",
      "Behavior change",
      "ABI change",
      "Storage layout change",
      "Config change",
      "Ready to commit"
    ],
    "field_owners": {
      "Change summary": "solidity-implementer|process-implementer",
      "Files reviewed": "solidity-implementer|process-implementer|verifier",
      "Task Brief path": "main-orchestrator",
      "Agent Report path": "main-orchestrator",
      "Semantic dimensions reviewed": "main-orchestrator",
      "Source-of-truth docs checked": "main-orchestrator",
      "External facts checked": "main-orchestrator",
      "Local control-flow facts checked": "main-orchestrator",
      "Evidence chain complete": "main-orchestrator",
      "Semantic alignment summary": "main-orchestrator",
      "Behavior change": "solidity-implementer|process-implementer",
      "ABI change": "solidity-implementer",
      "Storage layout change": "solidity-implementer",
      "Config change": "solidity-implementer|process-implementer",
      "Security review summary": "security-reviewer",
      "Security residual risks": "security-reviewer",
      "Open safety mismatches assessed": "security-reviewer|verifier|main-orchestrator",
      "Security evidence source": "security-reviewer",
      "Gas-sensitive paths reviewed": "gas-reviewer",
      "Gas changes applied": "gas-reviewer",
      "Gas snapshot/result": "gas-reviewer",
      "Gas residual risks": "gas-reviewer",
      "Gas evidence source": "gas-reviewer",
      "Docs updated": "solidity-implementer|process-implementer",
      "Tests updated": "solidity-implementer|process-implementer|security-test-writer",
      "Existing tests exercised": "solidity-implementer|process-implementer|security-test-writer",
      "Rule-map evidence source": "verifier",
      "Commands run": "verifier",
      "Results": "verifier",
      "Verification evidence source": "verifier",
      "Ready to commit": "main-orchestrator",
      "Decision evidence source": "main-orchestrator",
      "Residual risks": "main-orchestrator|verifier|security-reviewer|gas-reviewer"
    },
    "owner_prefixed_source_fields": [
      "Security evidence source",
      "Gas evidence source",
      "Verification evidence source",
      "Decision evidence source",
      "Rule-map evidence source"
    ],
    "placeholder_values": [
      "",
      "TBD",
      "<path>",
      "<path>|none",
      "<selectors or paths>",
      "<agent-report-path>",
      "<verification-source>",
      "<decision-source>",
      "<rule-id or mapped-tests>",
      "yes/no"
    ]
  },
  "solidity_review_note": {
    "required_fields": [
      "Task Brief path",
      "Agent Report path",
      "Implementation owner",
      "Writer dispatch confirmed"
    ],
    "boolean_fields": [
      "Writer dispatch confirmed"
    ],
    "task_brief_field": "Task Brief path",
    "agent_report_field": "Agent Report path",
    "implementation_owner_field": "Implementation owner",
    "writer_dispatch_confirmed_field": "Writer dispatch confirmed"
  },
  "pull_request": {
    "required_sections": [
      "## Summary",
      "## Impact",
      "## Docs",
      "## Tests",
      "## Verification",
      "## Risks",
      "## Security",
      "## Simplification",
      "## Gas"
    ]
  },
  "rule_map": {
    "path": "docs/process/rule-map.json",
    "role": "memeverse-specific-machine-readable-truth",
    "enforced_by": [
      "script/process/check-rule-map.sh",
      "script/process/check-solidity-review-note.sh"
    ],
    "evidence_field": "Existing tests exercised"
  },
  "agents": {
    "main_session_role": "main-orchestrator",
    "main_session_forbidden_write_patterns": [
      "^src/.*\\.sol$",
      "^test/.*\\.sol$",
      "^test/.*\\.t\\.sol$",
      "^script/.*\\.sh$"
    ],
    "require_task_brief_before_write_patterns": [
      "^src/.*\\.sol$",
      "^test/.*\\.sol$",
      "^test/.*\\.t\\.sol$"
    ],
    "required_writer_for_patterns": {
      "^src/.*\\.sol$": "solidity-implementer",
      "^test/.*\\.sol$": "solidity-implementer",
      "^test/.*\\.t\\.sol$": "solidity-implementer",
      "^(AGENTS\\.md|README\\.md|docs/process/.*|docs/reviews/(TEMPLATE|README)\\.md|docs/task-briefs/.*|docs/agent-reports/.*|docs/(ARCHITECTURE|GLOSSARY|TRACEABILITY|VERIFICATION)\\.md|docs/spec/.*|docs/adr/.*|\\.github/pull_request_template\\.md|\\.codex/.*)$": "process-implementer",
      "^(script/.*\\.sh|\\.githooks/.*)$": "process-implementer"
    },
    "default_roles": [
      "solidity-implementer",
      "process-implementer",
      "security-reviewer",
      "gas-reviewer",
      "verifier"
    ],
    "on_demand_roles": [
      "solidity-explorer",
      "security-test-writer"
    ],
    "task_brief_directory": "docs/task-briefs",
    "agent_report_directory": "docs/agent-reports",
    "task_brief_template": ".codex/templates/task-brief.md",
    "agent_report_template": ".codex/templates/agent-report.md",
    "agent_directory": ".codex/agents"
  },
  "quality_gate": {
    "swap_src_sol_pattern": "^src/swap/.*\\.sol$",
    "src_sol_pattern": "^src/.*\\.sol$",
    "test_tsol_pattern": "^test/.*\\.t\\.sol$",
    "test_sol_pattern": "^test/.*\\.sol$",
    "shell_pattern": "^(script/.*\\.sh|\\.githooks/.*)$",
    "package_pattern": "^(package\\.json|package-lock\\.json)$",
    "lint_command": "npm run lint:sol",
    "docs_contract_pattern": "^(AGENTS\\.md|README\\.md|docs/process/.*|docs/reviews/(TEMPLATE|README)\\.md|docs/task-briefs/.*|docs/agent-reports/.*|docs/(ARCHITECTURE|GLOSSARY|TRACEABILITY|VERIFICATION)\\.md|docs/spec/.*|docs/adr/.*|\\.github/pull_request_template\\.md|\\.codex/.*)$",
    "review_note_directory": "docs/reviews",
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions",
    "coverage": {
      "enabled": true,
      "report_file": "coverage/lcov.info",
      "exclude_tests": true,
      "ir_minimum": true,
      "quick_metrics": "line,function",
      "only_changed_tiers": true,
      "fail_on_missing_data": true,
      "default_thresholds": {
        "line": 75,
        "function": 75,
        "branch": 30
      },
      "tiers": [
        {
          "path": "src/common",
          "line": 80,
          "function": 80,
          "branch": 30
        },
        {
          "path": "src/verse",
          "line": 78,
          "function": 78,
          "branch": 30
        },
        {
          "path": "src/swap",
          "line": 78,
          "function": 78,
          "branch": 30
        },
        {
          "path": "src/governance",
          "line": 75,
          "function": 75,
          "branch": 30
        },
        {
          "path": "src/yield",
          "line": 75,
          "function": 75,
          "branch": 30
        },
        {
          "path": "src/interoperation",
          "line": 72,
          "function": 72,
          "branch": 30
        },
        {
          "path": "src/token",
          "line": 72,
          "function": 72,
          "branch": 30
        }
      ]
    },
    "src_default_roles": [
      "solidity-implementer",
      "security-reviewer",
      "gas-reviewer",
      "verifier"
    ],
    "src_optional_roles": [
      "solidity-explorer",
      "security-test-writer"
    ],
    "test_default_roles": [
      "solidity-implementer",
      "verifier"
    ],
    "test_optional_roles": [
      "security-reviewer",
      "gas-reviewer"
    ],
    "shell_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "package_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "docs_contract_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "hard_block_conditions": [
      "required_command_failed",
      "main_session_unauthorized_write_to_restricted_path",
      "missing_required_writer_dispatch_for_restricted_path",
      "missing_task_brief_before_solidity_write",
      "unauthorized_write_out_of_scope",
      "missing_security_or_gas_evidence_for_src_change",
      "missing_semantic_alignment_evidence_for_semantic_sensitive_change",
      "confirmed_finding_missing_evidence_chain",
      "review_note_invalid_for_src_change",
      "rule_map_evidence_requirement_failed"
    ],
    "soft_block_conditions": [
      "explained_non_critical_gas_regression",
      "deferrable_simplification",
      "non_blocking_docs_follow_up",
      "pending_human_product_decision"
    ]
  }
}
