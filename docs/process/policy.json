{
  "review_note": {
    "required_headings": [
      "## Scope",
      "## Impact",
      "## Findings",
      "## Simplification",
      "## Gas",
      "## Docs",
      "## Tests",
      "## Verification",
      "## Decision"
    ],
    "required_fields": [
      "Change summary",
      "Files reviewed",
      "Behavior change",
      "ABI change",
      "Storage layout change",
      "Config change",
      "Security review summary",
      "Security residual risks",
      "Gas-sensitive paths reviewed",
      "Gas changes applied",
      "Gas snapshot/result",
      "Gas residual risks",
      "Docs updated",
      "Tests updated",
      "Existing tests exercised",
      "Commands run",
      "Results",
      "Ready to commit",
      "Residual risks"
    ],
    "boolean_fields": [
      "Behavior change",
      "ABI change",
      "Storage layout change",
      "Config change",
      "Ready to commit"
    ],
    "placeholder_values": [
      "",
      "TBD",
      "<path>",
      "<path>|none",
      "<selectors or paths>",
      "yes/no"
    ]
  },
  "pull_request": {
    "required_sections": [
      "## Summary",
      "## Impact",
      "## Docs",
      "## Tests",
      "## Verification",
      "## Risks",
      "## Security",
      "## Simplification",
      "## Gas"
    ]
  },
  "quality_gate": {
    "swap_src_sol_pattern": "^src/swap/.*\\.sol$",
    "src_sol_pattern": "^src/.*\\.sol$",
    "test_tsol_pattern": "^test/.*\\.t\\.sol$",
    "test_sol_pattern": "^test/.*\\.sol$",
    "shell_pattern": "^(script/.*\\.sh|\\.githooks/.*)$",
    "review_note_directory": "docs/reviews",
    "slither_baseline_file": "docs/process/slither.baseline",
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions",
    "gas_snapshot_file": "docs/process/gas-snapshot.baseline",
    "gas_snapshot_tolerance_percent": "5"
  }
}
